# Copy this to .env.local and fill in your values
# Never commit .env.local to git

# Required: Your Anthropic API key
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Your CalCentral session cookie for schedule conflict checking
# How to get: Log into CalCentral → DevTools (F12) → Application → Cookies
# → calcentral.berkeley.edu → copy value of _calcentral_session
# Leave blank to skip conflict checking
CALCENTRAL_SESSION_COOKIE=
